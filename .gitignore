# ── Environment files (contain secrets) ──
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Generated runtime config (compiled from .env) ──
js/config.js

# ── Node modules (if any) ──
node_modules/

# ── OS / Editor artifacts ──
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/

# ── Scratch / temp dev files ──
scratch/

# ── One-off test scripts ──
test-*.js

# ── Internal dev reports (not user-facing) ──
PR_NOTIFICATION_FIX.md
TEST_REPORT.md

# ── Vercel local cache ──
.vercel/
