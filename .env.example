# ═══════════════════════════════════════════════════════════
# ANISMOKE — Environment Variables
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════

# Supabase — Auth & Database
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Consumet API — Optional self-hosted stream backup
# Leave empty if not using. Deploy via docker/ or Render/Vercel.
ANISMOKE_CONSUMET=
